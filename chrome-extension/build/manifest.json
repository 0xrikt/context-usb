{
  "manifest_version": 3,
  "name": "Context USB",
  "version": "1.0.0",
  "description": "让 AI 读懂你 — 一键将个人上下文注入任意 AI 对话",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://context-usb.vercel.app/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://context-usb.vercel.app/*"],
      "js": ["content-scripts/context-reader.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.deepseek.com/*",
        "https://kimi.moonshot.cn/*",
        "https://www.doubao.com/*"
      ],
      "js": ["content-scripts/injector.js"],
      "run_at": "document_idle"
    }
  ]
}
